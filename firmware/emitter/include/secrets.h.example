#pragma once

/**
 * Copy this file to ``include/secrets.h`` and fill in Wi‑Fi + API key + Emitter TLS server PEMs.
 * After upgrading firmware, merge new keys from ``secrets.h.example`` if your copy predates
 * ``EMITTER_SERVER_*``, ``EMITTER_HTTPS_PORT``, or ``EMITTER_SIMULATE_BUSY_MS`` support.
 * ``include/secrets.h`` is gitignored; PlatformIO copies this example automatically
 * on first build if ``secrets.h`` is missing (placeholder values will not work on device).
 *
 * TLS: Default CA below is **ISRG Root X1** (Let's Encrypt). If Catalog uses another issuer,
 * replace ``CATALOG_CA_PEM`` with the PEM from Catalog’s “Export for Emitter” notes (REFERENCE.md §3).
 */

#define WIFI_SSID "YOUR_WIFI_SSID"
#define WIFI_PASSWORD "YOUR_WIFI_PASSWORD"

/** Same secret as Catalog ``IRPETE_API_KEY`` (REFERENCE.md §4). */
#define IRPETE_API_KEY "YOUR_IRPETE_API_KEY"

#define CATALOG_HOST "catalog.home.example"
#define CATALOG_PORT 8443

/** Stored label to fetch (must exist in Catalog DB). */
#define CATALOG_LABEL "tv_power"

/** BearSSL HTTPS listener for POST /v1/play (REFERENCE.md §5). */
#define EMITTER_HTTPS_PORT 8443

/**
 * Optional busy window (milliseconds) before contacting Catalog: queued HTTPS clients get 409.
 * Use for bench overlap testing (two curls); keep 0 in production.
 */
#define EMITTER_SIMULATE_BUSY_MS 0

/**
 * Emitter TLS **server** certificate + private key (full PEM text).
 * Replace with your leaf (or wildcard) used by curl/SNI (**IRPETE_EMITTER_FQDN** in catalog/.env.example).
 * The blocks below are a **development self-signed** pair for CN=emitter.home.example only.
 */
