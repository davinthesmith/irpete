#pragma once

/**
 * Copy this file to ``include/secrets.h`` and fill in Wi‑Fi + API key + Pete TLS server PEMs.
 * After upgrading firmware, merge new keys from ``secrets.h.example`` if your copy predates Stage 6
 * (``PETE_SERVER_*``, ``PETE_HTTPS_PORT``, ``PETE_SIMULATE_BUSY_MS``).
 * ``include/secrets.h`` is gitignored; PlatformIO copies this example automatically
 * on first build if ``secrets.h`` is missing (placeholder values will not work on device).
 *
 * TLS: Default CA below is **ISRG Root X1** (Let's Encrypt). If Peter uses another issuer,
 * replace ``PETER_CA_PEM`` with the PEM from Stage 3 “Export for Pete” (REFERENCE.md §3).
 */

#define WIFI_SSID "YOUR_WIFI_SSID"
#define WIFI_PASSWORD "YOUR_WIFI_PASSWORD"

/** Same secret as Peter ``IRPETE_API_KEY`` (REFERENCE.md §4). */
#define IRPETE_API_KEY "YOUR_IRPETE_API_KEY"

#define PETER_HOST "peter.toomanyprojects.dev"
#define PETER_PORT 8443

/** Stored label to fetch (must exist in Peter DB). */
#define PETER_LABEL "tv_power"

/** BearSSL HTTPS listener for POST /v1/play (REFERENCE.md §5 Stage 6). */
#define PETE_HTTPS_PORT 8443

/**
 * Optional busy window (milliseconds) before contacting Peter: queued HTTPS clients get 409.
 * Use for bench overlap testing (two curls); keep 0 in production.
 */
#define PETE_SIMULATE_BUSY_MS 0

/**
 * Pete TLS **server** certificate + private key (full PEM text).
 * Replace with your leaf (or wildcard) used by curl/SNI (e.g. pete.toomanyprojects.dev).
 * The blocks below are a **development self-signed** pair for CN=pete.toomanyprojects.dev only.
 */
