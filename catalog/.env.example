# Copy to `.env` (never commit `.env`). Values below are examples only.

# Required: shared Bearer secret for `/v1/*` (including `/v1/health`).
IRPETE_API_KEY=change-me-to-a-long-random-secret

# SQLite database file (directory is created if missing). Defaults to `data/irpete.db` under `catalog/`.
# IRPETE_DB_PATH=/path/to/irpete.db

# Bind address and port. Dev HTTP defaults: 127.0.0.1:8000. Production HTTPS on the Pi: use
# IRPETE_HOST=0.0.0.0 and IRPETE_PORT=8443 (recommended; avoids binding privileged 443).
IRPETE_HOST=127.0.0.1
IRPETE_PORT=8000

# TLS (production / LAN). When both are set, `python -m irpete.main` serves HTTPS via Uvicorn.
# Paths are typically `/etc/irpete/fullchain.pem` and `/etc/irpete/privkey.pem` on the Pi.
# Leave unset for local HTTP development only (do not expose HTTP on the LAN for operators).
# IRPETE_TLS_CERTFILE=/path/to/fullchain.pem
# IRPETE_TLS_KEYFILE=/path/to/privkey.pem

# Set to 1 to hide /docs, /redoc, and OpenAPI JSON on instances exposed to the network.
# IRPETE_DISABLE_OPENAPI=1

# Operator / firmware hostnames (not read by the Python server; used in curl/openssl snippets
# and as the source of truth to copy into Emitter secrets.h). Replace placeholders with your LAN DNS.
IRPETE_CATALOG_FQDN=catalog.home.example
IRPETE_EMITTER_FQDN=emitter.home.example
# Optional: Pi LAN IP for curl --resolve when split-horizon DNS is not set up on the client.
IRPETE_LAN_IP=192.168.1.50
