# Install on the Pi as /etc/irpete/catalog.env (root-owned, chmod 600).
# Do not commit real values.

IRPETE_API_KEY=replace-with-long-random-secret

IRPETE_HOST=0.0.0.0
IRPETE_PORT=8443

IRPETE_TLS_CERTFILE=/etc/irpete/fullchain.pem
IRPETE_TLS_KEYFILE=/etc/irpete/privkey.pem

# Recommended: absolute path so restarts always use the same DB regardless of cwd.
# IRPETE_DB_PATH=/var/lib/irpete/irpete.db

# Optional on exposed LAN instances
# IRPETE_DISABLE_OPENAPI=1

# Operator / firmware hostnames (not read by the Python server; used in curl/openssl snippets).
IRPETE_CATALOG_FQDN=catalog.home.example
IRPETE_EMITTER_FQDN=emitter.home.example
# Optional: Pi LAN IP for curl --resolve from a laptop without LAN DNS.
IRPETE_LAN_IP=192.168.1.50
