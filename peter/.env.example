# Copy to `.env` (never commit `.env`). Values below are examples only.

# Required: shared Bearer secret for `/v1/*` (including `/v1/health`).
IRPETE_API_KEY=change-me-to-a-long-random-secret

# SQLite database file (directory is created if missing). Defaults to `data/irpete.db` under `peter/`.
# IRPETE_DB_PATH=/path/to/irpete.db

# Bind address and port for local HTTP (Stage 1 has no TLS; Stage 3 adds HTTPS).
IRPETE_HOST=127.0.0.1
IRPETE_PORT=8000
